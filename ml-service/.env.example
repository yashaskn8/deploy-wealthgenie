# WealthGenie ML service environment configuration
# Copy this file to .env inside ml-service for local overrides.

# Path to the trained RandomForest model file.
# Defaults to ml-service/model/model.pkl when omitted.
MODEL_PATH=./model/model.pkl

# Comma-separated frontend/backend origins allowed to call the FastAPI service.
CORS_ORIGINS=http://localhost:5000,http://localhost:5173,http://127.0.0.1:5000,http://127.0.0.1:5173

# Port used by uvicorn when running main.py directly.
PORT=8000

# Shared inter-service API key for secure communication with Express backend.
ML_SERVICE_API_KEY=wealthgenie_secret_api_key_2026
