# =========================================================================
# 🧞‍♂️ WEALTHGENIE UNIFIED ENVIRONMENT CONFIGURATION
# =========================================================================

# ── Express API Backend Server ───────────────────────────────────────────
# Port where the Node Express server will listen
PORT=5000
# Run environment: "development" (enables verbose errors) or "production"
NODE_ENV=development
# MongoDB connection URI (use 'mongodb://mongodb:27017/wealthgenie' for local docker-compose)
MONGODB_URI=mongodb://localhost:27017/wealthgenie
# Redis cache/rate limit connection URI (use 'redis://redis:6379' for local docker-compose)
REDIS_URL=redis://localhost:6379
# JWT Secret Key (min 32 characters for security)
JWT_SECRET=super_secret_jwt_token_at_least_32_characters_long
# Session expiry time (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d
# CORS allowed origins (comma-separated whitelisted domains)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── Machine Learning (FastAPI) Microservice ──────────────────────────────
# ML service root URL (Express backend uses this to query RandomForest/SHAP predictions)
ML_SERVICE_URL=http://localhost:8000
# Port for FastAPI ML Service
ML_PORT=8000
# Shared inter-service authentication key (protects FastAPI endpoints)
ML_SERVICE_API_KEY=wealthgenie_secret_api_key_2026
# Path to RandomForest model pickle file (defaults to ./model/model.pkl)
MODEL_PATH=./model/model.pkl

# ── AI Integrations (External APIs) ──────────────────────────────────────
# Google Gemini API key (enables AI financial advisory chat)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional Groq API key failover (for Llama models)
GROQ_API_KEY=your_groq_api_key_here

# ── Frontend (Vite App) ──────────────────────────────────────────────────
# API Server base URL for Vite frontend communication
VITE_API_URL=http://localhost:5000/api
