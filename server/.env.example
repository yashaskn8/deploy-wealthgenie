# 🧞‍♂️ WealthGenie Express Backend Environment Configuration
# Use this template file to create your own local ".env" file in the "server" directory.

# =========================================================================
# 🖥️ SERVER CONFIGURATION
# =========================================================================

# The port where your local Express API backend server will run.
# Default is 5000. If changed, ensure the frontend matches this port.
PORT=5000

# The execution environment. Use "development" for local coding (enables
# verbose error logs) or "production" for deployed setups.
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call this API.
# Local Vite and preview defaults are included below.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173


# =========================================================================
# 📊 DATABASE CONFIGURATION (MongoDB)
# =========================================================================

# The connection string for your MongoDB database.
# For local setup: mongodb://localhost:27017/wealthgenie
# For cloud setups: Use MongoDB Atlas.
# To get a free cloud database cluster, sign up at: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wealthgenie?retryWrites=true&w=majority


# =========================================================================
# 🔑 SECURITY & SESSION MANAGEMENT (JWT)
# =========================================================================

# JSON Web Token (JWT) secret key used to sign and verify user session tokens.
# Keep this extremely secure! For development, any long random string will do.
# For production, generate a secure 64-character hex key (e.g. via running `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
JWT_SECRET=your_64_char_hex_secret_here_replace_this_with_a_real_secret_key_64ch

# How long a user session remains active before requiring a log in again.
# Formats: "7d" (7 days), "24h" (24 hours), "2h" (2 hours).
JWT_EXPIRES_IN=7d


# =========================================================================
# ⚡ CACHING & RATE LIMITING (Redis)
# =========================================================================

# Connection URL for your Redis server.
# Used for rate-limiting API requests and caching AI model prompts to save token costs.
# For local Redis: redis://localhost:6379
# For a free hosted Redis instance, sign up at Upstash: https://console.upstash.com
REDIS_URL=redis://localhost:6379


# =========================================================================
# 🤖 MACHINE LEARNING MICROSERVICE URL
# =========================================================================

# The local URL where the Python FastAPI machine learning microservice is running.
# Default is http://localhost:8000.
ML_SERVICE_URL=http://localhost:8000


# =========================================================================
# 🧠 AI CHAT INTEGRATION (Google Gemini API)
# =========================================================================

# Your API Key to access Google's Gemini models (used for the financial advisory chat).
# Get a free developer key at Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional failover API key for Groq-hosted Llama models used by chat fallback.
# Leave blank if Groq failover is not configured.
GROQ_API_KEY=your_groq_api_key_here

# Shared inter-service API key for secure communication with FastAPI ML microservice.
ML_SERVICE_API_KEY=wealthgenie_secret_api_key_2026

