{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wealthgenie.app/schemas/investment_master.json",
  "title": "WealthGenie Investment Master Catalog",
  "description": "Canonical schema for the 110-instrument investment database used across frontend, backend, and validation pipelines.",
  "type": "object",
  "required": ["catalogVersion", "generatedAt", "instruments"],
  "properties": {
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the catalog (e.g. 1.0.0)"
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of catalog generation"
    },
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Instrument" }
    }
  },
  "definitions": {
    "Instrument": {
      "type": "object",
      "required": [
        "id", "slug", "name", "category", "assetClass",
        "metadata", "staticData", "dynamicData", "eligibility"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique machine-readable identifier (e.g. ppf, sbi_fd)"
        },
        "slug": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "URL-friendly unique slug"
        },
        "name": {
          "type": "string",
          "minLength": 3,
          "description": "Human-readable display name"
        },
        "abbr": {
          "type": "string",
          "description": "Short abbreviation for UI cards"
        },
        "category": {
          "type": "string",
          "enum": [
            "Government",
            "Bank Deposits",
            "Debt Mutual Funds",
            "Equity Mutual Funds",
            "Hybrid Mutual Funds",
            "Sector/Thematic Mutual Funds",
            "International Mutual Funds",
            "ETFs",
            "Gold",
            "REITs & InvITs",
            "Bonds & Debentures",
            "Retirement",
            "Insurance-linked",
            "Direct Equity",
            "Other"
          ]
        },
        "assetClass": {
          "type": "string",
          "enum": [
            "Sovereign",
            "Cash",
            "Debt",
            "Equity",
            "Hybrid",
            "Gold",
            "Real Estate",
            "Commodity",
            "International",
            "Other"
          ]
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Hex color code for UI rendering"
        },
        "eligibility": { "$ref": "#/definitions/Eligibility" },
        "metadata": { "$ref": "#/definitions/Metadata" },
        "staticData": { "$ref": "#/definitions/StaticData" },
        "dynamicData": { "$ref": "#/definitions/DynamicData" }
      },
      "additionalProperties": false
    },

    "Metadata": {
      "type": "object",
      "required": ["version", "lastUpdated", "reviewedBy", "sourceConfidence"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "lastUpdated": {
          "type": "string",
          "description": "Date string (YYYY-MM-DD or human-readable)"
        },
        "reviewedBy": {
          "type": "string",
          "minLength": 1
        },
        "sourceConfidence": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        }
      },
      "additionalProperties": false
    },

    "StaticData": {
      "type": "object",
      "required": [
        "description", "pros", "cons", "faq",
        "taxation", "whereToInvest", "suitability", "alternatives"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 20,
          "description": "Comprehensive instrument description (no placeholders)"
        },
        "pros": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 10 }
        },
        "cons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 10 }
        },
        "faq": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/FAQ" }
        },
        "taxation": { "$ref": "#/definitions/Taxation" },
        "whereToInvest": { "$ref": "#/definitions/WhereToInvest" },
        "suitability": { "$ref": "#/definitions/Suitability" },
        "trustBadge": { "$ref": "#/definitions/TrustBadge" },
        "alternatives": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Array of instrument IDs for cross-linking"
        },
        "explainer": { "$ref": "#/definitions/Explainer" },
        "cardSubtitle": {
          "type": "string",
          "description": "One-line plain-language subtitle for recommendation cards"
        }
      },
      "additionalProperties": false
    },

    "DynamicData": {
      "type": "object",
      "required": [
        "expectedReturn", "risk", "liquidity",
        "minMonthlyInvestment", "idealHorizon", "goalTags"
      ],
      "properties": {
        "expectedReturn": { "$ref": "#/definitions/ExpectedReturn" },
        "expenseRatio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 5
        },
        "interestRates": {
          "type": ["number", "null"],
          "description": "Current stated interest rate if applicable"
        },
        "fundSize": {
          "type": ["string", "null"],
          "description": "AUM or corpus size as display string"
        },
        "topSchemes": {
          "type": "array",
          "items": { "$ref": "#/definitions/TopScheme" }
        },
        "risk": { "$ref": "#/definitions/Risk" },
        "liquidity": { "$ref": "#/definitions/Liquidity" },
        "minMonthlyInvestment": {
          "type": "number",
          "minimum": 0
        },
        "maxAnnualInvestment": {
          "type": ["number", "null"]
        },
        "idealHorizon": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "goalTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "taxType": {
          "type": "string",
          "enum": ["eee", "slab", "ltcg", "elss", "nps", "sgb"],
          "description": "Tax computation key for scoring engine"
        },
        "taxEfficiencyScore": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 5
        },
        "lockIn": {
          "type": "number",
          "minimum": 0,
          "description": "Lock-in period in years"
        },
        "liquidityScore": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 5
        },
        "volatility": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "riskLevel": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "description": "Numeric risk score for scoring engine"
        }
      },
      "additionalProperties": false
    },

    "ExpectedReturn": {
      "type": "object",
      "required": ["min", "avg", "max", "source", "lastUpdated"],
      "properties": {
        "min": { "type": "number" },
        "avg": { "type": "number" },
        "max": { "type": "number" },
        "source": { "type": "string", "minLength": 3 },
        "lastUpdated": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },

    "Risk": {
      "type": "object",
      "required": ["level", "value", "volatility"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["Very Low", "Low", "Low-Medium", "Medium-Low", "Medium", "High", "Very High"]
        },
        "value": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "volatility": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },

    "Liquidity": {
      "type": "object",
      "required": ["score", "type", "lockIn"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "type": {
          "type": "string",
          "enum": ["T+0", "T+1", "T+2", "T+3", "N/A"]
        },
        "lockIn": {
          "type": "number",
          "minimum": 0,
          "description": "Lock-in period in years"
        }
      },
      "additionalProperties": false
    },

    "Taxation": {
      "type": "object",
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["eee", "slab", "ltcg", "elss", "nps", "sgb"]
        },
        "section": {
          "type": ["string", "null"],
          "description": "Tax section reference (e.g. 80C, 80CCD(1B))"
        },
        "taxFreeInterest": {
          "type": "boolean"
        },
        "stcg": {
          "type": ["string", "null"],
          "description": "Short-term capital gains treatment"
        },
        "ltcg": {
          "type": ["string", "null"],
          "description": "Long-term capital gains treatment"
        },
        "indexation": {
          "type": ["boolean", "null"],
          "description": "Whether indexation benefit applies"
        },
        "details": {
          "type": "string",
          "minLength": 10
        }
      },
      "additionalProperties": false
    },

    "WhereToInvest": {
      "type": "object",
      "required": ["howToStart", "platforms"],
      "properties": {
        "howToStart": {
          "type": "string",
          "minLength": 10
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "Suitability": {
      "type": "object",
      "required": ["idealFor", "whoShouldAvoid"],
      "properties": {
        "idealFor": { "type": "string", "minLength": 10 },
        "whoShouldAvoid": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },

    "TrustBadge": {
      "type": "object",
      "required": ["type", "label", "body", "desc"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sovereign", "rbi", "insured", "sebi", "regulated", "rated"]
        },
        "label": { "type": "string", "minLength": 3 },
        "body": { "type": "string", "minLength": 3 },
        "desc": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },

    "Explainer": {
      "type": "object",
      "required": ["what", "riskPlain", "lockInPlain", "whoFor"],
      "properties": {
        "what": { "type": "string", "minLength": 20 },
        "riskPlain": { "type": "string", "minLength": 10 },
        "lockInPlain": { "type": "string", "minLength": 10 },
        "whoFor": { "type": "string", "minLength": 10 },
        "example": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "FAQ": {
      "type": "object",
      "required": ["question", "answer"],
      "properties": {
        "question": { "type": "string", "minLength": 10 },
        "answer": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },

    "TopScheme": {
      "type": "object",
      "required": ["name", "provider", "rate", "highlight", "platform", "minInvestment"],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "provider": { "type": "string", "minLength": 2 },
        "rate": { "type": "string" },
        "highlight": { "type": "string", "minLength": 20 },
        "platform": { "type": "string", "minLength": 2 },
        "minInvestment": { "type": "string" },
        "tenure": { "type": ["string", "null"] },
        "badge": { "type": ["string", "null"] },
        "sector": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "Eligibility": {
      "type": "object",
      "required": ["minAge", "maxAge", "minAnnualIncome", "minMonthlySavings"],
      "properties": {
        "minAge": { "type": "number", "minimum": 0 },
        "maxAge": { "type": ["number", "null"], "minimum": 0 },
        "minAnnualIncome": { "type": "number", "minimum": 0 },
        "minMonthlySavings": { "type": "number", "minimum": 0 },
        "notes": { "type": ["string", "null"] },
        "requiresDemat": { "type": ["boolean", "null"] },
        "hasGirlChild": { "type": ["boolean", "null"] }
      },
      "additionalProperties": false
    }
  }
}
